[importlinter]
root_package = app
include_external_packages = True

[importlinter:contract:api_v2_routers_do_not_import_repositories]
name = FastAPI v2 routers should not import repositories directly
type = forbidden
allow_indirect_imports = True
source_modules =
    app.api_v2_routers
forbidden_modules =
    app.repositories
ignore_imports =
    app.api_v2_routers.consent -> app.repositories.*
    app.api_v2_routers.gamification -> app.repositories.*
    app.api_v2_routers.learners -> app.repositories.*
    app.api_v2_routers.onboarding -> app.repositories.*
    app.api_v2_routers.parents -> app.repositories.*
    app.api_v2_routers.study_plans -> app.repositories.*

[importlinter:contract:popia_router_uses_dependency_layer]
name = POPIA router uses dependency layer rather than repository construction
type = forbidden
allow_indirect_imports = True
source_modules =
    app.api_v2_routers.popia
forbidden_modules =
    app.repositories
    app.core.database
    sqlalchemy

[importlinter:contract:lessons_router_uses_authorization_service_layer]
name = Lessons router uses authorization service layer rather than repositories
type = forbidden
allow_indirect_imports = True
source_modules =
    app.api_v2_routers.lessons
forbidden_modules =
    app.repositories
