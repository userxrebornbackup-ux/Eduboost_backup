# the file with real credentials.

SUPABASE_PG_HOST=db.ezjzbvybbwynqpqnbrdt.supabase.co
SUPABASE_PG_PORT=5432
SUPABASE_PG_DB=postgres
SUPABASE_PG_USER=postgres
