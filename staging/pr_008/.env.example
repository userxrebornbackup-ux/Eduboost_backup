# ─────────────────────────────────────────────────────────────────────────────
# EduBoost SA — Environment Variables
#
# [IMMEDIATE FIX 2] Consolidated from two conflicting files (.env.example and
#                   env.example) into this single authoritative source.
#
# Copy to .env and fill in all values before running:
#   cp .env.example .env
#
# ⚠  NEVER commit a populated .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── APPLICATION ───────────────────────────────────────────────────────────────
APP_ENV=development                          # development | staging | production
APP_NAME=EduBoost SA
APP_VERSION=0.1.0
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
ALLOWED_ORIGINS=http://localhost:3050        # comma-separated CORS origins


# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────────────
# For local Docker stack: credentials must match the postgres service below.
# For production: use a managed database URL from your cloud provider.
POSTGRES_DB=eduboost
POSTGRES_USER=eduboost_user
POSTGRES_PASSWORD=CHANGE_ME_devpassword

# Async SQLAlchemy connection string (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://eduboost_user:CHANGE_ME_devpassword@localhost:5432/eduboost

# Sync connection string (used by Alembic migrations)
# Keep this consistent with DATABASE_URL above — only the driver prefix changes.
SYNC_DATABASE_URL=postgresql+psycopg2://eduboost_user:CHANGE_ME_devpassword@localhost:5432/eduboost


# ── REDIS (Cache + Celery broker) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Legacy archive only: if you run the retired RabbitMQ-based stack outside V2,
# never use guest/guest in production.
RABBITMQ_USER=CHANGE_ME_required_for_legacy_stack_in_production
RABBITMQ_PASSWORD=CHANGE_ME_required_for_legacy_stack_in_production


# ── AUTHENTICATION & ENCRYPTION ──────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_long_random_secret_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 32-byte (256-bit) Fernet-compatible key for field-level encryption.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_32_byte_base64_encoded_key
ENCRYPTION_SALT=CHANGE_ME_random_salt_for_key_derivation
AUDIT_HMAC_SECRET=CHANGE_ME_random_audit_hmac_secret
BACKUP_ENCRYPTION_KEY=CHANGE_ME_random_backup_encryption_key
BACKUP_RETENTION_DAYS=30


# ── AI / LLM PROVIDERS ───────────────────────────────────────────────────────
# Groq — primary inference provider (fast, Llama 3 based)
GROQ_API_KEY=gsk_CHANGE_ME

# Anthropic Claude — secondary / fallback provider
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# HuggingFace — used by the offline inference service only
HUGGINGFACE_API_KEY=hf_CHANGE_ME

# Default models to use per provider
GROQ_MODEL=llama3-8b-8192
ANTHROPIC_MODEL=claude-sonnet-4-6
OFFLINE_MODEL_NAME=google/flan-t5-base

# Local Hugging Face provider for development/testing of trained CAPS adapters.
# Use local_hf only on a machine that can afford loading the model in the API process.
LLM_PROVIDER=auto                              # auto | groq | anthropic | local_hf | mock
LOCAL_BASE_MODEL_ID=HuggingFaceTB/SmolLM2-360M-Instruct
LOCAL_ADAPTER_PATH=artifacts/llm/smollm2-caps-focused-9epoch-adapter
LOCAL_MERGED_MODEL_PATH=artifacts/llm/merged-smollm2-caps-focused-model
LOCAL_LLM_MAX_NEW_TOKENS=900
LOCAL_LLM_TEMPERATURE=0.2


# ── INFERENCE SERVICE ─────────────────────────────────────────────────────────
# Internal URL for the dedicated PyTorch inference container.
# In Docker Compose this resolves via service name; override for local dev.
INFERENCE_SERVICE_URL=http://localhost:9100
INFERENCE_PORT=9100
MODEL_CACHE_DIR=/root/.cache/huggingface


# ── EMAIL (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME
EMAIL_FROM=noreply@eduboost.co.za
EMAIL_FROM_NAME=EduBoost SA
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_sendgrid_password


# ── STORAGE (Cloudflare R2 / S3-compatible) ───────────────────────────────────
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=eduboost-assets
R2_ENDPOINT_URL=https://CHANGE_ME.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://assets.eduboost.co.za


# ── MONITORING & OBSERVABILITY ────────────────────────────────────────────────
# Sentry DSN — leave blank to disable error tracking in development
SENTRY_DSN=

# Grafana admin password (local dev only)
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_CLOUD_PROMETHEUS_URL=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_API_KEY=
ALERTMANAGER_SLACK_WEBHOOK=


# ── NEXT.JS FRONTEND (public — visible to browsers) ──────────────────────────
# These NEXT_PUBLIC_ variables are embedded into the client bundle at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v2
NEXT_PUBLIC_APP_NAME=EduBoost SA
NEXT_PUBLIC_SENTRY_DSN=


# ── SUPABASE (optional — only if using Supabase Auth or Storage) ──────────────
# If you are using a self-managed Postgres instance (recommended), leave these
# blank and ensure DATABASE_URL points directly to your Postgres host.
# See docs/architecture.md for the Supabase vs raw-Postgres decision.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ── POPIA / COMPLIANCE ────────────────────────────────────────────────────────
# Email address for the Information Officer (required by POPIA s.55)
POPIA_INFORMATION_OFFICER_EMAIL=privacy@eduboost.co.za
# Retention period in days for learner session data
DATA_RETENTION_DAYS=365
# Whether parental consent is enforced at the API layer (must be true in prod)
REQUIRE_PARENTAL_CONSENT=true


# ── SECRETS MANAGER (Medium-Term / Production only) ──────────────────────────
# In production, these values are sourced from Azure Key Vault instead of this file.
# Required secret names:
#   eduboost-jwt-secret
#   eduboost-encryption-key
#   eduboost-encryption-salt
#   eduboost-groq-api-key
#   eduboost-anthropic-api-key
AZURE_KEY_VAULT_URL=https://CHANGE_ME.vault.azure.net/
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
