/* ─────────────────────────────────────────────────────────────────────────────
   EduBoost SA — globals.css  (upgraded)
   Deep Tech Ocean design system — premium utility layer
   ───────────────────────────────────────────────────────────────────────────── */

@tailwind base;
@tailwind components;
@tailwind utilities;

/* ── CSS custom properties (shadcn/ui + brand) ─────────────────────────────── */
@layer base {
  :root {
    --background:  222 47% 6%;
    --foreground:  180 5% 95%;
    --card:        220 32% 10%;
    --card-foreground: 180 5% 95%;
    --popover:     220 32% 10%;
    --popover-foreground: 180 5% 95%;
    --primary:     185 100% 40%;
    --primary-foreground: 222 47% 6%;
    --secondary:   215 30% 18%;
    --secondary-foreground: 180 5% 85%;
    --muted:       215 30% 14%;
    --muted-foreground: 200 15% 55%;
    --accent:      185 100% 40%;
    --accent-foreground: 222 47% 6%;
    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 98%;
    --border:      216 24% 18%;
    --input:       216 24% 18%;
    --ring:        185 100% 40%;
    --radius:      0.625rem;
  }
}

/* ── Smooth base ────────────────────────────────────────────────────────────── */
@layer base {
  * {
    @apply border-border;
  }

  html {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    scroll-behavior: smooth;
  }

  body {
    @apply bg-navy-950 text-cream font-sans;
    font-feature-settings: "cv02", "cv03", "cv04", "cv11";
  }

  /* Focus ring — visible only on keyboard navigation */
  :focus-visible {
    outline: 2px solid rgba(0, 207, 209, 0.65);
    outline-offset: 2px;
    border-radius: var(--radius);
  }
}

/* ── Component layer ────────────────────────────────────────────────────────── */
@layer components {

  /* ── Navigation item ─────────────────────────────────────────────────────── */
  .nav-item {
    @apply flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium
           text-cream-muted/60 transition-all duration-200
           hover:bg-navy-700/70 hover:text-cream;
  }
  .nav-item.active {
    @apply bg-gradient-to-r from-navy-700/80 to-navy-700/30 text-cream shadow-inner-border;
  }

  /* ── Metric card base ────────────────────────────────────────────────────── */
  .metric-card {
    @apply relative flex flex-col gap-4 overflow-hidden rounded-2xl border
           border-navy-700/60 bg-navy-800/70 p-5 backdrop-blur-sm
           transition-all duration-300;
  }

  /* ── Glass surface ────────────────────────────────────────────────────────── */
  .glass {
    background: rgba(10, 22, 40, 0.72);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
  }

  /* ── Glass card (elevated) ───────────────────────────────────────────────── */
  .glass-card {
    @apply rounded-2xl border border-white/[0.06] bg-navy-800/60 backdrop-blur-md;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.04) inset,
      0 8px 24px rgba(0,0,0,0.4);
  }

  /* ── Gradient text ───────────────────────────────────────────────────────── */
  .text-gradient {
    @apply bg-gradient-to-r from-electric-400 to-aqua-400 bg-clip-text text-transparent;
  }

  /* ── Badges ──────────────────────────────────────────────────────────────── */
  .badge-base {
    @apply inline-flex items-center rounded-full px-2.5 py-1 text-2xs font-semibold border;
  }
  .badge-aqua    { @apply badge-base bg-aqua-900/40 text-aqua-300 border-aqua-800/60; }
  .badge-electric{ @apply badge-base bg-electric-900/40 text-electric-300 border-electric-800/60; }
  .badge-teal    { @apply badge-base bg-teal-900/40 text-teal-300 border-teal-800/60; }
  .badge-success { @apply badge-base bg-success/10 text-success border-success/20; }
  .badge-error   { @apply badge-base bg-error/10 text-error border-error/20; }
  .badge-warning { @apply badge-base bg-warning/10 text-warning border-warning/20; }

  /* ── Input focus glow ────────────────────────────────────────────────────── */
  .input-glow:focus-within {
    box-shadow: 0 0 0 3px rgba(0, 207, 209, 0.06);
  }

  /* ── Gradient divider ────────────────────────────────────────────────────── */
  .divider-gradient {
    @apply h-px bg-gradient-to-r from-transparent via-navy-600 to-transparent;
  }

  /* ── Background grid patterns ────────────────────────────────────────────── */
  .grid-pattern {
    background-image:
      linear-gradient(rgba(0, 207, 209, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 207, 209, 0.06) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .grid-pattern-sm {
    background-image:
      linear-gradient(rgba(0, 207, 209, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 207, 209, 0.04) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  /* ── Shimmer (loading skeleton) ──────────────────────────────────────────── */
  .shimmer {
    position: relative;
    overflow: hidden;
  }
  .shimmer::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
    animation: shimmer 1.8s ease-in-out infinite;
  }

  /* ── Gradient border via pseudo-element ─────────────────────────────────── */
  .gradient-border {
    position: relative;
    border-radius: var(--radius);
  }
  .gradient-border::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(0,207,209,0.25), rgba(13,127,192,0.15), rgba(0,207,209,0.05));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* ── Animated-in utility (used instead of tailwind-animate) ─────────────── */
  .animate-in-up {
    animation: fade-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── Stagger helpers ─────────────────────────────────────────────────────── */
  .stagger-1 { animation-delay:  60ms; }
  .stagger-2 { animation-delay: 120ms; }
  .stagger-3 { animation-delay: 180ms; }
  .stagger-4 { animation-delay: 240ms; }

  /* ── Dashboard layout helpers ────────────────────────────────────────────── */
  .dashboard-layout {
    @apply flex h-screen overflow-hidden bg-navy-950;
  }
  .dashboard-content {
    @apply flex flex-1 flex-col overflow-hidden;
  }
  .dashboard-main {
    @apply flex-1 overflow-y-auto overflow-x-hidden;
    padding-top: theme("spacing.topbar");
  }
  .dashboard-page {
    @apply mx-auto max-w-7xl p-6 space-y-6;
  }

  /* ── Scroll bar styling ──────────────────────────────────────────────────── */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 207, 209, 0.2) transparent;
  }
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: rgba(0, 207, 209, 0.2);
    border-radius: 2px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 207, 209, 0.35);
  }
}

/* ── Utility layer extras ───────────────────────────────────────────────────── */
@layer utilities {
  /* Tabular numbers for counters / values */
  .tabular   { font-variant-numeric: tabular-nums; }
  .lining    { font-variant-numeric: lining-nums; }

  /* Safe bottom padding on mobile */
  .pb-safe   { padding-bottom: env(safe-area-inset-bottom, 0px); }

  /* Clip text utility */
  .text-clip { -webkit-background-clip: text; background-clip: text; }
}
