{
  "name": "eduboost-sa-frontend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3050",
    "build": "next build",
    "start": "next start -p 3050",
    "lint": "next lint --no-cache",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "env-check": "python ../../scripts/validate_frontend_env.py",
    "a11y-check": "vitest run src/__tests__/AccessibilityContracts.test.tsx",
    "pr-007-check": "npm run env-check && npm run type-check && npm run test"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "0.15.0",
    "@supabase/supabase-js": "^2.105.3",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "framer-motion": "11.2.6",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7",
    "swr": "2.2.5",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@types/node": "20.12.7",
    "@types/react": "18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^24.0.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.4.5",
    "vitest": "^1.6.1"
  }
}
