{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "EduBoost Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "description": "EduBoost PostgreSQL data source",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "EduBoost SA — CAPS Item Bank Coverage Dashboard (Phase 5, P5-09)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "Coverage Matrix Doc",
      "tooltip": "Open the CAPS coverage matrix markdown",
      "type": "link",
      "url": "https://github.com/nkgolo-lebelo/Eduboost/blob/master/docs/caps/grade4_maths_coverage_matrix.md"
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📚 Item Bank Coverage — Grade 4 Mathematics",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Coverage ratio = approved items / 40 target. Alert fires below 0.8.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green",  "value": 1.0 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "item_bank_coverage_ratio{caps_ref=\"4.M.1.1\"}",
          "legendFormat": "4.M.1.1 Whole Numbers",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "item_bank_coverage_ratio{caps_ref=\"4.M.1.2\"}",
          "legendFormat": "4.M.1.2 Common Fractions",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "item_bank_coverage_ratio{caps_ref=\"4.M.1.3\"}",
          "legendFormat": "4.M.1.3 2D Shapes",
          "refId": "C"
        }
      ],
      "title": "Coverage Ratio by CAPS Ref",
      "type": "gauge"
    },

    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "description": "Approved item count per CAPS ref vs 40-item target.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "mappings": [],
          "max": 60,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 30 },
              { "color": "green",  "value": 40 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT caps_ref AS \"CAPS Ref\", COUNT(*) AS \"Approved Items\" FROM diagnostic_items WHERE review_status = 'approved' AND safety_passed = TRUE AND caps_ref IN ('4.M.1.1','4.M.1.2','4.M.1.3') GROUP BY caps_ref ORDER BY caps_ref",
          "refId": "A"
        }
      ],
      "title": "Approved Items per CAPS Ref (target: 40)",
      "type": "bargauge"
    },

    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "description": "Breakdown of review pipeline state for each launch CAPS ref.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "color-background-solid",
            "filterable": false,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "approved" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",    "value": null },
                    { "color": "orange", "value": 20 },
                    { "color": "green",  "value": 40 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background-solid" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": {
        "footer": { "enablePagination": false, "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT caps_ref, COUNT(*) FILTER (WHERE review_status='draft') AS draft, COUNT(*) FILTER (WHERE review_status='ai_generated') AS ai_generated, COUNT(*) FILTER (WHERE review_status='human_reviewed') AS human_reviewed, COUNT(*) FILTER (WHERE review_status='approved') AS approved, COUNT(*) FILTER (WHERE review_status='retired') AS retired FROM diagnostic_items WHERE caps_ref IN ('4.M.1.1','4.M.1.2','4.M.1.3') GROUP BY caps_ref ORDER BY caps_ref",
          "refId": "A"
        }
      ],
      "title": "Review Pipeline Status by CAPS Ref",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "📊 Difficulty Distribution & IRT Parameters",
      "type": "row"
    },

    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "description": "Distribution of approved items across difficulty bands per CAPS ref.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "multi", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT caps_ref, COUNT(*) FILTER (WHERE difficulty_b < -1.0) AS \"Easy (b<-1)\", COUNT(*) FILTER (WHERE difficulty_b >= -1.0 AND difficulty_b < 0) AS \"Moderate (-1≤b<0)\", COUNT(*) FILTER (WHERE difficulty_b >= 0 AND difficulty_b < 1) AS \"On-Level (0≤b<1)\", COUNT(*) FILTER (WHERE difficulty_b >= 1.0) AS \"Challenging (b≥1)\" FROM diagnostic_items WHERE review_status='approved' AND caps_ref IN ('4.M.1.1','4.M.1.2','4.M.1.3') GROUP BY caps_ref ORDER BY caps_ref",
          "refId": "A"
        }
      ],
      "title": "Difficulty Distribution (Approved Items)",
      "type": "barchart"
    },

    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "description": "Per-item quality scores for approved items. Target: all ≥ 0.7.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green",  "value": 0.7 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": {
        "footer": { "show": false },
        "showHeader": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT caps_ref, ROUND(AVG(quality_score)::numeric,3) AS avg_quality, ROUND(MIN(quality_score)::numeric,3) AS min_quality, COUNT(*) FILTER (WHERE quality_score < 0.7) AS below_threshold FROM diagnostic_items WHERE review_status='approved' AND caps_ref IN ('4.M.1.1','4.M.1.2','4.M.1.3') AND quality_score IS NOT NULL GROUP BY caps_ref",
          "refId": "A"
        }
      ],
      "title": "Item Quality Scores (target ≥ 0.7)",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "🔁 Exposure Tracking",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Coverage ratio over time. Alert when ratio drops below 0.8.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "item_bank_coverage_ratio",
          "legendFormat": "{{caps_ref}}",
          "refId": "A"
        }
      ],
      "title": "Coverage Ratio Over Time",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
      "description": "Items approaching or at their exposure cap. Items at cap are excluded from future selection.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "displayMode": "color-background-solid", "filterable": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 40 },
              { "color": "red",    "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "options": { "footer": { "show": false }, "showHeader": true },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRES}" },
          "format": "table",
          "rawSql": "SELECT di.caps_ref, di.item_id, di.exposure_count, di.max_exposure, ROUND((di.exposure_count::float / NULLIF(di.max_exposure,0) * 100)::numeric, 1) AS pct_used FROM diagnostic_items di WHERE di.review_status = 'approved' AND di.caps_ref IN ('4.M.1.1','4.M.1.2','4.M.1.3') AND di.exposure_count > (di.max_exposure * 0.6) ORDER BY pct_used DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Items > 60% Exposure Cap",
      "type": "table"
    }
  ],
  "schemaVersion": 38,
  "tags": ["eduboost", "item-bank", "caps", "grade4", "mathematics", "phase5"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "Africa/Johannesburg",
  "title": "EduBoost — CAPS Item Bank Coverage (Grade 4 Maths)",
  "uid": "eduboost-item-bank-coverage-g4m",
  "version": 1,
  "weekStart": "monday"
}
